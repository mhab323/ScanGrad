<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="14dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/iv_submission_avatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_avatar"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_doc"
            android:contentDescription="Submission avatar" />

        <TextView
            android:id="@+id/tv_status_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/pill_grade_high"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:text="A+"
            android:textColor="@color/grade_high"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/iv_chevron"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_toEndOf="@id/tv_status_badge"
            android:layout_centerVertical="true"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_chevron_right"
            app:tint="@color/outline" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/iv_submission_avatar"
            android:layout_toStartOf="@id/tv_status_badge"
            android:layout_centerVertical="true"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/tv_submission_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:ellipsize="end"
                android:fontFamily="@font/plus_jakarta"
                android:maxLines="1"
                android:text="Sarah J."
                android:textColor="@color/on_surface"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_submission_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_submission_title"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Math Quiz • 10 Oct"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp" />
        </RelativeLayout>
    </RelativeLayout>

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/pb_grading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:indeterminate="true"
        app:indicatorColor="@color/primary"
        app:trackColor="@color/primary_soft"
        app:trackCornerRadius="2dp"
        android:visibility="gone" />

</LinearLayout>
