<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        android:scrollbars="none">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="30dp">

            <ImageView
                android:id="@+id/iv_app_logo"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="false"
                android:src="@drawable/book"
                 />

            <TextView
                android:id="@+id/tv_app_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/iv_app_logo"
                android:layout_marginStart="8dp"
                android:text="ScanGrad"
                android:textColor="@color/primary_blue"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_greeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_app_name"
                android:layout_marginTop="32dp"
                android:text="Hello, Mohammad"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_greeting_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_greeting"
                android:layout_marginTop="4dp"
                android:text="Ready for today's curriculum?"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <RelativeLayout
                android:id="@+id/card_academic_standing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_greeting_subtitle"
                android:layout_marginTop="24dp"
                android:background="@drawable/rounded_edittext_bg"
                android:padding="20dp">

                <TextView
                    android:id="@+id/badge_academic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/input_background"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:text="ACADEMIC STANDING"
                    android:textColor="@color/text_primary"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_success_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/badge_academic"
                    android:layout_marginTop="12dp"
                    android:text="94.2% Success Rate"
                    android:textColor="@color/primary_blue"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_success_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tv_success_rate"
                    android:layout_marginTop="8dp"
                    android:text="Your recent exam scans show a high level of accuracy. You've completed 12 graded submissions this week."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/card_scanned_docs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/card_academic_standing"
                android:layout_marginTop="16dp"
                android:background="@drawable/rounded_edittext_bg"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_scanned_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SCANNED DOCUMENTS"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_scanned_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tv_scanned_label"
                    android:layout_marginTop="4dp"
                    android:text="148"
                    android:textColor="@color/primary_blue"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_scanned_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/tv_scanned_count"
                    android:layout_alignBaseline="@id/tv_scanned_count"
                    android:layout_marginStart="8dp"
                    android:text="Total"
                    android:textColor="@color/primary_blue"
                    android:textSize="14sp" />

            </RelativeLayout>

            <TextView
                android:id="@+id/tv_recent_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/card_scanned_docs"
                android:layout_marginTop="32dp"
                android:text="Recent Submissions"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_view_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignBaseline="@id/tv_recent_header"
                android:text="View All >"
                android:textColor="@color/primary_blue"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recent_submissions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_recent_header"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_recent_submission" />

        </RelativeLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_scanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:src="@drawable/camera"
        app:backgroundTint="@color/primary_blue"
        app:tint="@color/surface_white"
        app:elevation="6dp" />

</RelativeLayout>