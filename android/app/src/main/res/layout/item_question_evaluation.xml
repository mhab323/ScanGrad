<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_card"
    android:orientation="horizontal"
    android:minHeight="64dp">

    <View
        android:id="@+id/v_accent"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="@color/grade_high" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Header: question number + score -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            >

            <TextView
                android:id="@+id/tv_question_id1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:fontFamily="@font/plus_jakarta"
                android:text="Question "
                android:textColor="@color/on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_question_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignEnd="@id/tv_question_id1"
                android:layout_alignParentStart="true"
                android:layout_marginStart="74dp"
                android:layout_marginEnd="-72dp"
                android:fontFamily="@font/plus_jakarta"
                android:text=""
                android:textColor="@color/on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_question_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:fontFamily="@font/plus_jakarta"
                android:text="10 / 10"
                android:textColor="@color/grade_high"
                android:textSize="16sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Question text -->
        <TextView
            android:id="@+id/tv_question_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Question text…"
            android:textColor="@color/on_surface"
            android:textSize="14sp" />

        <!-- Student's answer -->
        <TextView
            android:id="@+id/lbl_student_answer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="STUDENT'S ANSWER"
            android:textColor="@color/on_surface_variant"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.04" />

        <TextView
            android:id="@+id/tv_student_answer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@color/surface_container"
            android:padding="12dp"
            android:text="—"
            android:textColor="@color/on_surface"
            android:textSize="14sp" />

        <!-- Feedback -->
        <TextView
            android:id="@+id/lbl_feedback"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="FEEDBACK"
            android:textColor="@color/on_surface_variant"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.04" />

        <TextView
            android:id="@+id/tv_question_feedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/inter"
            android:text="Feedback…"
            android:textColor="@color/on_surface"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>
