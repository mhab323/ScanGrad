<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme — Academic Precision. -->
    <style name="Base.Theme.ScanGrad" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Brand colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>
        <item name="colorSecondary">@color/primary_dark</item>
        <item name="colorOnSecondary">@color/on_primary</item>

        <!-- Surfaces -->
        <item name="android:colorBackground">@color/canvas</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_container</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <item name="colorOutline">@color/outline</item>
        <item name="colorError">@color/danger</item>

        <!-- Type -->
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>

        <!-- System bars -->
        <item name="android:statusBarColor">@color/canvas</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>

    <style name="Theme.ScanGrad" parent="Base.Theme.ScanGrad" />
</resources>
